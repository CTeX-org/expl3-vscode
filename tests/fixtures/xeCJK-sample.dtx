% Sample fixture excerpted from ctex-kit/xeCJK/xeCJK.dtx.
% Purpose: eyeball regression of the tmLanguage grammar.
%<@@=xeCJK>

%<*package>
\NeedsTeXFormat{LaTeX2e}
\RequirePackage{expl3}
\GetIdInfo$Id: xeCJK.dtx v3.10.2 2026-07-05 Liam Huang$
  {Typesetting CJK scripts with XeLaTeX}
\ProvidesExplPackage
  {\ExplFileName}{\ExplFileDate}{\ExplFileVersion}{\ExplFileDescription}

% ---- variables (three prefixes) ----
\tl_new:N   \g_@@_last_node_tl
\bool_new:N \l_@@_latin_punct_bool
\int_new:N  \l_@@_begin_int
\dim_new:N  \l_@@_ecglue_skip
\tl_const:Nn \c_@@_marker_tl { \tex_kern:D 0 pt }

% ---- private functions under @@ namespace ----
\cs_new_protected:Npn \@@_patch_codedoc_meta:
  {
    \cs_if_exist:NTF \__codedoc_meta:n
      {
        \cs_if_exist:NF \@@_orig_codedoc_meta:n
          {
            \cs_set_eq:NN \@@_orig_codedoc_meta:n \__codedoc_meta:n
            \cs_gset_protected:Npn \__codedoc_meta:n ##1
              {
                \mode_if_math:F { \@@_drain_ecglue_verb: }
                \@@_orig_codedoc_meta:n { \hbox:n {##1} }
              }
          }
      }
      {
        \bool_lazy_and:nnT
          { \cs_if_exist_p:c { ver@doc.sty } }
          { \cs_if_free_p:N \@@_orig_codedoc_meta:n }
          {
            \cs_set_eq:NN \@@_orig_codedoc_meta:n \meta
            \DeclareDocumentCommand \meta { m }
              {
                \mode_if_math:F { \@@_drain_ecglue_verb: }
                \@@_orig_codedoc_meta:n { \hbox:n {##1} }
              }
          }
      }
  }

% ---- quarks and scan marks ----
\quark_new:N  \q_@@_recursion_tail
\scan_new:N   \s_@@_stop
\use_none_delimit_by_q_stop:w
  \tex_ifx:D \q_stop \q_stop \tex_fi:D
  \q_stop

% ---- API family calls (colored as support.function) ----
\clist_map_inline:Nn \l_@@_punct_family_clist
  { \prop_gput:Nnn \g_@@_metric_prop {##1} { 0 pt } }
\int_compare:nNnTF { \l_@@_begin_int } < { 3 }
  { \tl_gput_right:Nn \g_@@_last_node_tl { default } }
  { \tl_gclear:N \g_@@_last_node_tl }

% ---- constants ----
\tl_set_eq:NN \l_tmpa_tl \c_novalue_tl
\bool_if:NTF \c_true_bool { \iow_now:Nn \g_iow_term:N { yes } } { }
%</package>

%<*driver>
\documentclass{l3doc}
\begin{document}
  \DocInput{\jobname.dtx}
\end{document}
%</driver>

