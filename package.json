{
  "name": "expl3-vscode",
  "displayName": "expl3 (LaTeX3) Language Support",
  "description": "Syntax highlighting and explcheck diagnostics for expl3 (LaTeX3) code.",
  "version": "0.2.3",
  "publisher": "CTeX-org",
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1E2A45",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "latex",
    "latex3",
    "expl3",
    "dtx",
    "docstrip",
    "explcheck",
    "linter",
    "syntax highlighting"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/CTeX-org/expl3-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/CTeX-org/expl3-vscode/issues"
  },
  "homepage": "https://github.com/CTeX-org/expl3-vscode#readme",
  "main": "./dist/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onLanguage:latex",
    "onLanguage:latex-expl3",
    "onLanguage:tex",
    "onLanguage:expl3"
  ],
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run compile -- --sourcemap --watch",
    "test": "node tests/grammar.test.mjs",
    "vscode:prepublish": "npm run compile -- --minify"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0",
    "vscode-oniguruma": "^2.0.0",
    "vscode-textmate": "^9.0.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "expl3",
        "aliases": [
          "expl3",
          "LaTeX3"
        ],
        "extensions": [
          ".expl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "expl3",
        "scopeName": "source.expl3",
        "path": "./syntaxes/expl3-base.tmLanguage.json"
      },
      {
        "scopeName": "expl3.injection",
        "path": "./syntaxes/expl3.tmLanguage.json",
        "injectTo": [
          "text.tex.latex",
          "text.tex.doctex",
          "text.tex.latex-expl3",
          "source.expl3"
        ]
      }
    ],
    "commands": [
      {
        "command": "expl3.check.run",
        "title": "expl3: Run explcheck on the active file"
      }
    ],
    "configuration": {
      "title": "expl3",
      "properties": {
        "expl3.check.enable": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable [`explcheck`](https://ctan.org/pkg/expltools) static-analysis diagnostics."
        },
        "expl3.check.path": {
          "type": "string",
          "default": "explcheck",
          "markdownDescription": "Path to the `explcheck` executable. Defaults to `explcheck` on `PATH` (provided by the TeX Live [`expltools`](https://ctan.org/pkg/expltools) package)."
        },
        "expl3.check.run": {
          "type": "string",
          "enum": [
            "onSave",
            "onType",
            "manual"
          ],
          "enumDescriptions": [
            "Run explcheck when a file is opened or saved.",
            "Run explcheck live as you type (debounced), plus on open/save.",
            "Only run explcheck via the 'expl3: Run explcheck' command."
          ],
          "default": "onSave",
          "markdownDescription": "When to run explcheck diagnostics. Use `onType` for live as-you-type checking."
        },
        "expl3.check.debounce": {
          "type": "number",
          "default": 400,
          "minimum": 100,
          "markdownDescription": "Debounce delay in milliseconds for `onType` checking."
        },
        "expl3.check.maxLineLength": {
          "type": "number",
          "default": 0,
          "markdownDescription": "Max line length before the `s103` (line too long) warning. `0` uses explcheck's default (80)."
        },
        "expl3.check.ignoredIssues": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Issue identifiers or prefixes to suppress (passed to `explcheck --ignored-issues`), e.g. `[\"s103\", \"w2\"]`."
        },
        "expl3.check.makeAtLetter": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Tokenize `@` as a letter (catcode 11), like in LaTeX `.sty` files (`explcheck --make-at-letter`)."
        }
      }
    }
  }
}
